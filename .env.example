AI_PROVIDER=gemini

# Gemini settings (used when AI_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# OpenAI settings (used when AI_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=

# Llama-compatible settings (used when AI_PROVIDER=llama)
LLAMA_API_KEY=your-llama-api-key
LLAMA_MODEL=meta-llama/llama-3.1-8b-instruct
LLAMA_BASE_URL=https://api.llmapi.ai/v1

# Shared prompt
SYSTEM_PROMPT=You are a helpful assistant.

# Qdrant settings
QDRANT_CHAT_COLLECTION=chat_sessions
